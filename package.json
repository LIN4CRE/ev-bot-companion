{
  "name": "@evbot/companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:web": "vite build",
    "start": "node dist/server.cjs",
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true }); if (fs.existsSync('server.js')) fs.unlinkSync('server.js');\"",
    "lint": "tsc --noEmit",
    "cap:add:android": "cap add android",
    "cap:build:android": "cap build android",
    "cap:open:android": "cap open android",
    "cap:sync": "cap sync",
    "android:build": "npm run build:web && npm run cap:sync && npm run cap:build:android",
    "android:dev": "npm run cap:sync && npm run cap:open:android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/toast": "^6.0.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dexie": "^4.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
